    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.2",
    "mongoose-autopopulate": "^1.1.0",
    "multer": "^1.4.5-lts.1",
    "redis": "^5.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.2.0",
    "@types/bcrypt": "^5.0.2",
